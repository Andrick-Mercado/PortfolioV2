@using PersonalPortfolio.Library.Domain
@using PersonalPortfolio.Library.Domain.Mappers
@using PersonalPortfolio.Library.Infrastructure.Extensions

<PageTitle>@ClientRouteName.FirstCharToUpper()</PageTitle>

@if (_hasLoaded is false)
{
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" Height="48px" Class="mb-8"/>
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="140px" Class="mb-4 rounded-xl"/>
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="140px" Class="mb-4 rounded-xl"/>
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="140px" Class="rounded-xl"/>
    </MudContainer>
}
else if (_currentPage?.PageFormat is CardType.Experience or CardType.Education)
{
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
            <MudIcon Icon="@IconMapper.GetIcon(_currentPage.Icon)" Color="Color.Primary" Size="Size.Large"/>
            <MudText Typo="Typo.h4"><b>@_currentPage.Title</b></MudText>
        </MudStack>
        <MudDivider Class="mb-8"/>

        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var card in _currentPage.Cards)
            {
                <MudTimelineItem Color="Color.Primary" Size="Size.Small" Elevation="0">
                    <ItemContent>
                        <MudCard Elevation="1" Class="rounded-xl mb-2">
                            <MudCardContent>
                                @if (string.IsNullOrEmpty(card.Period) is false)
                                {
                                    <MudChip T="string" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Class="ml-n1 mb-2">@card.Period</MudChip>
                                }
                                <MudText Typo="Typo.h6"><b>@card.Title</b></MudText>
                                @if (string.IsNullOrEmpty(card.Subtitle) is false)
                                {
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">@card.Subtitle</MudText>
                                }
                                <MudText Typo="Typo.body2" Style="line-height:1.7;">@card.Body</MudText>

                                @if (card.Tags.Any())
                                {
                                    <MudStack Row="true" Spacing="1" Class="mt-3 flex-wrap">
                                        @foreach (var tag in card.Tags)
                                        {
                                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@tag</MudChip>
                                        }
                                    </MudStack>
                                }
                            </MudCardContent>
                            @if (string.IsNullOrEmpty(card.LearnMoreUrl) is false)
                            {
                                <MudCardActions>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.OpenInNew"
                                               Href="@card.LearnMoreUrl" Target="_blank">Learn More</MudButton>
                                </MudCardActions>
                            }
                        </MudCard>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    </MudContainer>
}
else if (_currentPage?.PageFormat is CardType.Project)
{
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
            <MudIcon Icon="@IconMapper.GetIcon(_currentPage.Icon)" Color="Color.Primary" Size="Size.Large"/>
            <MudText Typo="Typo.h4"><b>@_currentPage.Title</b></MudText>
        </MudStack>
        <MudDivider Class="mb-8"/>

        <MudGrid Spacing="4">
            @foreach (var project in _currentPage.Cards)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" Class="rounded-xl d-flex flex-column" Style="height:100%;">
                        <MudCardContent Class="flex-grow-1">
                            <MudAvatar Color="Color.Primary" Rounded="true" Class="mb-4">
                                <MudIcon Icon="@IconMapper.GetIcon(project.Icon)"/>
                            </MudAvatar>
                            <MudText Typo="Typo.h6"><b>@project.Title</b></MudText>
                            @if (string.IsNullOrEmpty(project.Subtitle) is false)
                            {
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">@project.Subtitle</MudText>
                            }
                            <MudText Typo="Typo.body2" Style="line-height:1.7;">@project.Body</MudText>

                            @if (project.Tags.Any())
                            {
                                <MudStack Row="true" Spacing="1" Class="mt-3 flex-wrap">
                                    @foreach (var tag in project.Tags)
                                    {
                                        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@tag</MudChip>
                                    }
                                </MudStack>
                            }
                        </MudCardContent>
                        @if (string.IsNullOrEmpty(project.LearnMoreUrl) is false)
                        {
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.OpenInNew"
                                           Href="@project.LearnMoreUrl" Target="_blank">Learn More</MudButton>
                            </MudCardActions>
                        }
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
}